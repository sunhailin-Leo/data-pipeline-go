{
    "streams": [
        {
            "name": "stream-nsq-http",
            "enable": true,
            "channel_size": 1000,
            "ack_mode": 0,
            "source": [
                {
                    "type": "NSQ",
                    "source_name": "nsq-1",
                    "nsq": {
                        "address": "127.0.0.1:4150",
                        "lookupd_address": "",
                        "topic": "data-pipeline-topic",
                        "channel": "data-pipeline-channel",
                        "max_in_flight": 100
                    }
                }
            ],
            "transform": {
                "mode": "json",
                "schemas": [
                    {
                        "source_key": "id",
                        "sink_key": "id",
                        "converter": "toString",
                        "is_ignore": false,
                        "is_strict_mode": true,
                        "is_keep_keys": true,
                        "source_name": "nsq-1",
                        "sink_name": "http-1"
                    },
                    {
                        "source_key": "payload",
                        "sink_key": "payload",
                        "converter": "",
                        "is_ignore": false,
                        "is_strict_mode": false,
                        "is_keep_keys": true,
                        "source_name": "nsq-1",
                        "sink_name": "http-1"
                    }
                ]
            },
            "sink": [
                {
                    "type": "HTTP",
                    "sink_name": "http-1",
                    "http": {
                        "url": "http://localhost:8080/api/v1",
                        "content_type": "application/json",
                        "headers": {
                            "key": "value"
                        }
                    }
                }
            ]
        }
    ]
}
